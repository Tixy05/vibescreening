digraph AnnotatedDFA {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=14, compound=true, label=<f — depth level 1>, labelloc=t, labeljust=c];
    node [shape=circle, fontname="Courier", fontsize=10];
    edge [fontname="Courier", fontsize=10];

    legend [shape=plain, label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="4"><tr><td colspan="2" bgcolor="#eeeeee"><b>index → pattern</b></td></tr><tr><td align="right">1</td><td align="left">e[b2]s</td></tr><tr><td align="right">2</td><td align="left">[b1 b2]es</td></tr><tr><td colspan="2" bgcolor="#eeeeee"><b>b_i → pattern</b></td></tr><tr><td align="right">b0</td><td align="left">∅</td></tr><tr><td align="right">b1</td><td align="left">e[b2]s</td></tr><tr><td align="right">b2</td><td align="left">[b1 b2]es</td></tr><tr><td align="right">b3</td><td align="left">e[b2]s | [b1 b2]es</td></tr></table>>];

    subgraph cluster_automaton {
        label="Annotated DFA";
        rankdir=LR;
        node [shape=circle, fontname="Courier", fontsize=10];
        edge [fontname="Courier", fontsize=10];

        _start [shape=point, width=0.15];
        _start -> 0;

        0 [shape=circle, label="0\n∅"];
        1 [shape=circle, label="1\n∅"];
        2 [shape=circle, label="2\n∅"];
        3 [shape=circle, label="3\n∅"];
        4 [shape=circle, label="4\n∅"];
        5 [shape=doublecircle, label="5\n{2}"];
        6 [shape=doublecircle, label="6\n{1,2}"];
        7 [shape=doublecircle, label="7\n{1}"];

        0 -> 1 [label="b0,s", color=black, fontcolor=black];
        0 -> 2 [label="b1", color=darkred, fontcolor=darkred];
        0 -> 3 [label="b2", color=darkgreen, fontcolor=darkgreen];
        1 -> 1 [label="b0,b1,s", color=black, fontcolor=black];
        1 -> 4 [label="b2", color=darkred, fontcolor=darkred];
        2 -> 2 [label="b0,b1", color=black, fontcolor=black];
        2 -> 3 [label="b2", color=darkred, fontcolor=darkred];
        2 -> 5 [label="s", color=darkgreen, fontcolor=darkgreen];
        3 -> 2 [label="b0,b1", color=black, fontcolor=black];
        3 -> 3 [label="b2", color=darkred, fontcolor=darkred];
        3 -> 6 [label="s", color=darkgreen, fontcolor=darkgreen];
        4 -> 1 [label="b0,b1", color=black, fontcolor=black];
        4 -> 4 [label="b2", color=darkred, fontcolor=darkred];
        4 -> 7 [label="s", color=darkgreen, fontcolor=darkgreen];
        5 -> 2 [label="b0,b1", color=black, fontcolor=black];
        5 -> 3 [label="b2", color=darkred, fontcolor=darkred];
        5 -> 5 [label="s", color=darkgreen, fontcolor=darkgreen];
        6 -> 2 [label="b0,b1", color=black, fontcolor=black];
        6 -> 3 [label="b2", color=darkred, fontcolor=darkred];
        6 -> 5 [label="s", color=darkgreen, fontcolor=darkgreen];
        7 -> 1 [label="b0,b1,s", color=black, fontcolor=black];
        7 -> 4 [label="b2", color=darkred, fontcolor=darkred];
    }

    legend -> 0 [style=invis, weight=0, lhead=cluster_automaton];
}