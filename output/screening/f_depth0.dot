digraph AnnotatedDFA {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=14, compound=true, label=<f — depth level 0>, labelloc=t, labeljust=c];
    node [shape=circle, fontname="Courier", fontsize=10];
    edge [fontname="Courier", fontsize=10];

    legend [shape=plain, label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="4"><tr><td colspan="2" bgcolor="#eeeeee"><b>index → pattern</b></td></tr><tr><td align="right">1</td><td align="left">t[b1 b3]</td></tr><tr><td align="right">2</td><td align="left">[b2 b3]s</td></tr><tr><td colspan="2" bgcolor="#eeeeee"><b>b_i → pattern</b></td></tr><tr><td align="right">b0</td><td align="left">∅</td></tr><tr><td align="right">b1</td><td align="left">t[b1 b3]</td></tr><tr><td align="right">b2</td><td align="left">[b2 b3]s</td></tr></table>>];

    subgraph cluster_automaton {
        label="Annotated DFA";
        rankdir=LR;
        node [shape=circle, fontname="Courier", fontsize=10];
        edge [fontname="Courier", fontsize=10];

        _start [shape=point, width=0.15];
        _start -> 0;

        0 [shape=circle, label="0\n∅"];
        1 [shape=circle, label="1\n∅"];
        2 [shape=circle, label="2\n∅"];
        3 [shape=circle, label="3\n∅", style=filled, fillcolor="#e0c4c4"];
        4 [shape=doublecircle, label="4\n{1}"];
        5 [shape=doublecircle, label="5\n{2}"];

        0 -> 1 [label="b0,b1,s", color=black, fontcolor=black];
        0 -> 2 [label="b2,b3", color=darkred, fontcolor=darkred];
        1 -> 3 [label="b0,b2,s", color=black, fontcolor=black];
        1 -> 4 [label="b1,b3", color=darkred, fontcolor=darkred];
        2 -> 3 [label="b0,b2", color=black, fontcolor=black];
        2 -> 4 [label="b1,b3", color=darkred, fontcolor=darkred];
        2 -> 5 [label="s", color=darkgreen, fontcolor=darkgreen];
        3 -> 3 [label="b0,b1,b2,b3,s", color=black, fontcolor=black];
        4 -> 3 [label="b0,b1,b2,b3,s", color=black, fontcolor=black];
        5 -> 3 [label="b0,b1,b2,b3,s", color=black, fontcolor=black];
    }

    legend -> 0 [style=invis, weight=0, lhead=cluster_automaton];
}