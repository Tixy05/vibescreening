digraph AnnotatedDFA {
    rankdir=LR;
    node [shape=circle, fontname="Courier", fontsize=10];
    edge [fontname="Courier", fontsize=10];

    _start [shape=point, width=0.15];
    _start -> 0;

    0 [shape=doublecircle, label="0\n{1}"];
    1 [shape=doublecircle, label="1\n{2}", style=filled, fillcolor="#e0c4c4"];

    0 -> 1 [label="b,s", color=black, fontcolor=black];
    1 -> 1 [label="b,s", color=black, fontcolor=black];
}